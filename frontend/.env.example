# Backend API (dev proxy target). Used only by Vite dev server.
BACKEND_URL=http://127.0.0.1:8000

# Base path or full URL for API requests from the app.
# In dev with proxy use /api (requests go to same origin, proxy forwards to BACKEND_URL).
# In production use full backend URL if front is on another domain, e.g. https://api.example.com
VITE_API_BASE=/api

# Optional: Overpass API URL for pharmacy map (default: https://overpass-api.de/api/interpreter)
# VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter
